<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:Shop.Presentation"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Shop.Presentation.MainWindow"
        Title="Arnes Elektronik"
        Icon="avares://Shop.Presentation/Assets/NoTextLogo.png"
        Background="{StaticResource BackgroundColor}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto, *, Auto">
            <local:HeaderView Grid.Row="0"/>
            <Button Grid.Row="0" HorizontalAlignment="Right" Click="ReloadContent">Developer Reload Content</Button>
            <ContentControl x:Name="PageContainer" Grid.Row="1" />
            <local:FooterView Grid.Row="2"/>
        </Grid>
    </ScrollViewer>
</Window>